# --- Google Service Account (значения возьмите из скачанного JSON ключа) ---
# Переносы строк в GOOGLE_SA_PRIVATE_KEY: вставьте ключ одной строкой и замените
# реальные переводы строк в PEM на двухсимвольную последовательность \n (обратный слэш + n).

GOOGLE_SA_TYPE=поле type из JSON
GOOGLE_SA_PROJECT_ID=поле project_id из JSON
GOOGLE_SA_PRIVATE_KEY_ID=поле private_key_id из JSON
GOOGLE_SA_PRIVATE_KEY=поле private_key из JSON (одна строка, переносы как \n)
GOOGLE_SA_CLIENT_EMAIL=поле client_email из JSON
GOOGLE_SA_CLIENT_ID=поле client_id из JSON
GOOGLE_SA_AUTH_URI=поле auth_uri из JSON (можно не менять — совпадает у Google)
GOOGLE_SA_TOKEN_URI=поле token_uri из JSON
GOOGLE_SA_AUTH_PROVIDER_X509_CERT_URL=поле auth_provider_x509_cert_url из JSON
GOOGLE_SA_CLIENT_X509_CERT_URL=поле client_x509_cert_url из JSON
GOOGLE_SA_UNIVERSE_DOMAIN=поле universe_domain из JSON (часто googleapis.com)

# Альтернатива GOOGLE_SA_* (не используйте одновременно с заполненными GOOGLE_SA_*):
# GOOGLE_SERVICE_ACCOUNT_JSON=
# GOOGLE_SERVICE_ACCOUNT_KEY=
# GOOGLE_APPLICATION_CREDENTIALS=

# --- PostgreSQL ---
# Одна строка POSTGRES_HOST: localhost — приложение на хосте; postgres — приложение в Docker рядом с сервисом postgres.
POSTGRES_HOST=localhost
# Для приложения внутри Docker до БД в том же compose всегда порт 5432.
POSTGRES_PORT=5432
# Проброс Postgres на хост (docker-compose.dev). Если 5432 свободен — можно 5432 или убрать.
POSTGRES_PUBLISH_PORT=5438
POSTGRES_USER=notice
POSTGRES_PASSWORD=notice
POSTGRES_DB=notice

# --- Telegram ---
API_TOKEN=токен_бота_от_BotFather

# --- Какую таблицу читать (Sheets API) ---
# ID из URL: https://docs.google.com/spreadsheets/d/ВОТ_ЭТОТ_ID/edit
GOOGLE_SHEETS_SPREADSHEET_ID=id между /d/ и /edit в ссылке на таблицу
# Диапазон A1: только нужные колонки и строки. Шесть колонок клиента — например A:F или Лист1!A:F
GOOGLE_SHEETS_RANGE=A:F
